APP_ENV=dev
LOG_LEVEL=INFO
DATABASE_PATH=./data/bot.db
POLL_INTERVAL_SECONDS=180
MAX_EVENTS_PER_CYCLE=15

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Safety first:
DRY_RUN=true
AUTO_EXECUTE=false
MAX_BET_USD=25
MIN_CONFIDENCE=0.65
MAX_DAILY_LOSS_USD=100
MIN_MARKET_VOLUME=5000

# Public feeds
POLYMARKET_EVENTS_URL=https://gamma-api.polymarket.com/events
WORLD_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://www.aljazeera.com/xml/rss/all.xml

# LLM #1
LLM_1_NAME=ModelA
LLM_1_BASE_URL=https://api.openai.com/v1
LLM_1_MODEL=gpt-4o-mini
LLM_1_API_KEY=

# LLM #2
LLM_2_NAME=ModelB
LLM_2_BASE_URL=
LLM_2_MODEL=
LLM_2_API_KEY=

# LLM #3
LLM_3_NAME=ModelC
LLM_3_BASE_URL=
LLM_3_MODEL=
LLM_3_API_KEY=
